# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobsy

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Telegram
TELEGRAM_BOT_TOKEN=

# Docker
DOCKER_BASE_URL=unix:///var/run/docker.sock
AGENT_IMAGE=phl-jobs-agent:latest

# Kubernetes (опционально)
USE_KUBERNETES=false
K8S_NAMESPACE=phl-jobsy

# Ports
AGENT_PORT_START=8100
AGENT_PORT_END=8200
